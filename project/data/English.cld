wtr": ["The perfectionist in you ", "CRIES TEARS OF BLOOD!!! "], "MWKdVWHQ": ["\\{HOW COULD YOU NOT HAVE ", "ENOUGH CANDLES?!?!!?\\}"], "MsfT6TjM": ["It's fine. Proceed."], "lmW8lB5l": ["The rune is faded."], "GCSJJMmR": ["The rune is faded."], "d6gvNVJ6": ["The rune is faded."], "7glZzw2f": ["The rune is faded."], "VD2kF2Xt": ["The rune is faded."], "VbdSQQrZ": ["These guys are dead."], "rJGcJ85R": ["And soulless."], "ZPLV59Sk": ["Given the state of the bodies, whatever ", "happened here can't have been too long ago."], "6LCZhCqQ": ["", "Got Blood!"], "4908TQB2": ["There's nothing to step on."], "R1dQf2Mr": ["There's nothing to step on."], "RvcBVFjq": ["There's nothing to step on."], "Y91ZCnjZ": ["There's nothing to step on."], "RrrfWRBF": ["There's nothing to step on."], "SYh1lhfr": ["\"(There's a soul roaming over there...)\""], "Yz7qM9rL": ["There's no way over."], "TnLMGHZL": ["", "Placed down the Sun Stone!"], "sySCVn0z": ["", "Placed down the Moon Stone!"], "2Tvv7qJ3": ["", "Placed down the Star Stone!"], "hFF4TFN7": ["You're out of flowers."], "DkRXClql": ["You're out of flowers."], "Gjr7R62n": ["It's a coffee mug..."], "CWTzK5yC": ["", "[ You've already unlocked this vision. ]"], "rFQnwKl1": ["[ Vision Unlocked! ]"], "PqP62wdY": ["", "[ Visions can be viewed in the Vision Room. ]"], "sW5mT842": ["", "[ That is, if you have access to the Vision Room... ]"], "xnF445gy": ["You're out of flowers."], "CpdPjFbp": ["", "Got a Bottle!"], "bqSKYS7C": ["", "AKA, a container."], "Z9C4CLR8": ["Intriguing as the void may ", "seem, you cannot levitate."], "96b0M8PC": ["Alas, let beings more ethereal ", "than you explore it."], "w35RYMnQ": ["\"(I can't pinpoint when it started.)\""], "Yg9kZkSr": ["\"(In some way I think I've always known...)\""], "5rthLR0N": ["\"(Maybe it's because I had to be ", "everything to her all at once?)\""], "43JMRMxr": ["\"(Did something get twisted?", "Is it my fault.....?)\""], "bQxY8ByT": ["\"(But I was a dumbass kid. I had no ", "idea how to